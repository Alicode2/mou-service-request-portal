{
  "openapi": "3.0.0",
  "info": {
    "title": "Miva Open University Service Request Portal API",
    "version": "1.0.0",
    "description": "REST API for submitting, tracking, assigning, and resolving Miva Open University facility maintenance service requests. Obtain a JWT from POST /api/auth/login or /api/auth/register, then send it as 'Authorization: Bearer <token>' on protected routes."
  },
  "servers": [{ "url": "/api" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "tags": [
    { "name": "Auth", "description": "Registration, login, current user" },
    { "name": "Requests", "description": "Service request CRUD, assignment, status updates" },
    { "name": "Users", "description": "Admin user management" },
    { "name": "Categories", "description": "Request category management" },
    { "name": "Reports", "description": "Dashboard summary and CSV export" }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new student/staff account",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "department": { "type": "string" },
                  "phone": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "User created, returns JWT" }, "400": { "description": "Validation error or email already exists" } }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login and receive a JWT",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": { "email": { "type": "string" }, "password": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Login successful" }, "401": { "description": "Invalid credentials" } }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get the currently authenticated user",
        "responses": { "200": { "description": "Current user" }, "401": { "description": "Not authorized" } }
      }
    },
    "/requests": {
      "get": {
        "tags": ["Requests"],
        "summary": "List service requests (scoped by role) with search/filter/pagination",
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["pending", "assigned", "in_progress", "completed", "closed", "rejected"] } },
          { "name": "priority", "in": "query", "schema": { "type": "string", "enum": ["low", "medium", "high", "urgent"] } },
          { "name": "category", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": { "200": { "description": "Paginated list of requests" } }
      },
      "post": {
        "tags": ["Requests"],
        "summary": "Submit a new service request (student_staff, admin), with optional evidence files",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["title", "description", "category", "location"],
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "category": { "type": "string", "description": "Category ObjectId" },
                  "location": { "type": "string" },
                  "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
                  "evidence": { "type": "array", "items": { "type": "string", "format": "binary" } }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Request created" }, "400": { "description": "Validation error" } }
      }
    },
    "/requests/{id}": {
      "get": {
        "tags": ["Requests"],
        "summary": "Get a single request with assignment and status history",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Request detail" }, "403": { "description": "Not permitted" }, "404": { "description": "Not found" } }
      },
      "put": {
        "tags": ["Requests"],
        "summary": "Update request details (owner while pending, or admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" }, "403": { "description": "Not permitted" } }
      },
      "delete": {
        "tags": ["Requests"],
        "summary": "Delete a request (admin, or owner while pending)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" }, "403": { "description": "Not permitted" } }
      }
    },
    "/requests/{id}/assign": {
      "post": {
        "tags": ["Requests"],
        "summary": "Assign a request to a maintenance officer (admin only)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["officerId"],
                "properties": { "officerId": { "type": "string" }, "notes": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "201": { "description": "Assigned" } }
      }
    },
    "/requests/{id}/status": {
      "patch": {
        "tags": ["Requests"],
        "summary": "Update request status / progress (assigned officer or admin)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "enum": ["pending", "assigned", "in_progress", "completed", "closed", "rejected"] },
                  "note": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Status updated" } }
      }
    },
    "/users": {
      "get": {
        "tags": ["Users"],
        "summary": "List users (admin only)",
        "parameters": [
          { "name": "role", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Paginated list of users" } }
      },
      "post": {
        "tags": ["Users"],
        "summary": "Create a user of any role (admin only)",
        "responses": { "201": { "description": "User created" } }
      }
    },
    "/users/{id}": {
      "put": {
        "tags": ["Users"],
        "summary": "Update a user (admin only)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Users"],
        "summary": "Delete a user (admin only)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/categories": {
      "get": { "tags": ["Categories"], "summary": "List active categories", "responses": { "200": { "description": "List" } } },
      "post": { "tags": ["Categories"], "summary": "Create category (admin only)", "responses": { "201": { "description": "Created" } } }
    },
    "/categories/{id}": {
      "put": {
        "tags": ["Categories"],
        "summary": "Update category (admin only)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Categories"],
        "summary": "Delete category (admin only)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/reports/summary": {
      "get": { "tags": ["Reports"], "summary": "Dashboard summary stats (admin only)", "responses": { "200": { "description": "Summary" } } }
    },
    "/reports/export/csv": {
      "get": { "tags": ["Reports"], "summary": "Export all requests as CSV (admin only)", "responses": { "200": { "description": "CSV file" } } }
    }
  }
}
